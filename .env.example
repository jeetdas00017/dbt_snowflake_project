# =====================================================================
# .env.example
# Copy to .env (or set as Airflow Variables/Connections) — never commit
# real credentials. Referenced by extract/, load/, and dbt profiles.
# =====================================================================

# ---- Source Postgres ----
PG_HOST=source-postgres.internal
PG_PORT=5432
PG_DATABASE=app_db
PG_USER=etl_reader
PG_PASSWORD=

# ---- Snowflake ----
SF_ACCOUNT=xy12345.region
SF_USER=etl_user
SF_PASSWORD=
SF_DATABASE=analytics
SF_SCHEMA=control
SF_WAREHOUSE=compute_wh
SF_ROLE=etl_role

# ---- S3 ----
S3_RAW_BUCKET=my-company-dwh-raw

# IAM role for Snowflake to assume when accessing S3
SNOWFLAKE_S3_IAM_ROLE=arn:aws:iam::123456789012:role/SnowflakeS3Role

# AWS credentials for boto3 (prefer an instance profile / IRSA over keys)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
